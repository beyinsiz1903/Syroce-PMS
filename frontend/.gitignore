# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
# NOTE: frontend/build is intentionally NOT ignored. The Cloud autoscale
# deploy packaging ("Repl layer") excludes gitignored paths, so the build
# produced during the deploy build step would be dropped before runtime,
# leaving the backend to serve only the health JSON instead of the SPA.
# Tracking the build output ensures it ships in the deployment image.

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Playwright auto-generated reports (regenerated each run)
playwright-business-report/
test-results-business/
