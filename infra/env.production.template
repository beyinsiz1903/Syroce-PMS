# Syroce PMS — Production Environment Template
# Copy to .env and fill in production values
#
# CRITICAL (Boot Blockers)
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/syroce_production
DB_NAME=syroce_production
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_48

# REDIS
REDIS_URL=redis://redis:6379/0
REDIS_MODE=standalone
REDIS_MAX_CONNECTIONS=100

# CORS & SECURITY
CORS_ORIGINS=https://pms.syroce.com

# MESSAGING — Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# MESSAGING — SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@syroce.com

# MESSAGING — WhatsApp
WHATSAPP_PROVIDER_KEY=your_whatsapp_key

# OBSERVABILITY
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=syroce-pms

# BACKUP
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/data/backups

# QUEUE
CELERY_BROKER_URL=redis://redis:6379/1

# SECRETS
SECRETS_PROVIDER=env

# ALERTING WEBHOOKS
OPS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
PAGERDUTY_WEBHOOK_URL=

# SCALING
BACKEND_REPLICAS=2
FRONTEND_REPLICAS=2
WORKER_REPLICAS=2
SCALING_MODE=multi

# GRAFANA
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
GRAFANA_ROOT_URL=https://grafana.syroce.com
