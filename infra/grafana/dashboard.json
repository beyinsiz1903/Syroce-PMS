{
  "dashboard": {
    "title": "Syroce Hotel PMS — Infrastructure",
    "uid": "syroce-infra",
    "timezone": "UTC",
    "refresh": "30s",
    "panels": [
      {
        "title": "API Request Rate",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rate(hotel_pms_http_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "API Latency (p95)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "histogram_quantile(0.95, rate(hotel_pms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Redis Health",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "hotel_pms_redis_connected", "legendFormat": "Connected"}
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8}
      },
      {
        "title": "Celery Task Rate",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rate(hotel_pms_celery_tasks_total[5m])", "legendFormat": "{{task_name}} {{status}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
      },
      {
        "title": "Worker Queue Depth",
        "type": "gauge",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "hotel_pms_worker_queue_depth", "legendFormat": "{{queue}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
      },
      {
        "title": "MongoDB Connections",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "hotel_pms_db_active_connections", "legendFormat": "Active"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rate(hotel_pms_errors_total[5m])", "legendFormat": "{{error_type}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20}
      },
      {
        "title": "WebSocket Connections",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "hotel_pms_websocket_connections", "legendFormat": "Connected"}
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8}
      },
      {
        "title": "Messaging Delivery Rate",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "rate(hotel_pms_messaging_delivered_total[5m])", "legendFormat": "{{channel}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28}
      },
      {
        "title": "ML Pipeline Duration",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {"expr": "hotel_pms_ml_pipeline_duration_seconds", "legendFormat": "{{pipeline}}"}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28}
      }
    ]
  }
}
