{
  "expo": {
    "name": "Syroce PMS",
    "slug": "syroce-pms-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "syrocepms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0b0f1a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syroce.pms",
      "infoPlist": {
        "NSCameraUsageDescription": "Kimlik tarama ve QR okuma için kamera kullanılır.",
        "NSPhotoLibraryUsageDescription": "Kimlik fotoğrafı seçmek için galeriye erişim gerekir.",
        "NSFaceIDUsageDescription": "Uygulama kilidini açmak için Face ID kullanılır."
      }
    },
    "android": {
      "package": "com.syroce.pms",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Kimlik tarama ve QR okuma için kamera kullanılır."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3b82f6",
          "androidMode": "default",
          "androidCollapsedTitle": "Syroce PMS"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Uygulama kilidini açmak için Face ID kullanılır."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "certPins": [],
      "certPinningRequired": false
    }
  }
}
