{
  "expo": {
    "name": "Syroce PMS",
    "slug": "syroce-pms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "syrocepms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f8fb",
      "dark": {
        "image": "./assets/splash-dark.png",
        "resizeMode": "contain",
        "backgroundColor": "#0b0f1a"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syroce.pms",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Kimlik tarama ve QR okuma için kamera kullanılır.",
        "NSPhotoLibraryUsageDescription": "Kimlik fotoğrafı seçmek için galeriye erişim gerekir.",
        "NSFaceIDUsageDescription": "Uygulama kilidini açmak için Face ID kullanılır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.syroce.pms",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f1a"
      },
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Kimlik tarama ve QR okuma için kamera kullanılır."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6",
          "androidMode": "default",
          "androidCollapsedTitle": "Syroce PMS"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Uygulama kilidini açmak için Face ID kullanılır."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "certPins": [],
      "certPinningRequired": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
